ShopSection:AddTextBox({
	Name = "Exclude Items",
	Placeholder = "e.g. Apple, Wheat, Crate_01",
	Default = "",
	Callback = function(v)
		excludedItems = {}
		if v and v ~= "" then
			for word in string.gmatch(v, "[^,]+") do
				local trimmed = word:gsub("^%s+", ""):gsub("%s+$", "")
				if trimmed ~= "" then
					table.insert(excludedItems, trimmed)
				end
			end
		end
		print("Excluded items:", table.concat(excludedItems, ", "))
	end
});

