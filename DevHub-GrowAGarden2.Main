-- =============================================
-- GAME DATA LOADING
-- =============================================

local gardens = Workspace:FindFirstChild("Gardens")
local Networking = require(ReplicatedStorage.SharedModules.Networking)

-- Find player's plot
local OwnerPlot = nil
local function getMyPlot()
	if not gardens then return nil end
	for _, plot in ipairs(gardens:GetChildren()) do
		if plot.Name:lower():find("plot") and plot:GetAttribute("Owner") == LocalPlayer.Name then
			return plot
		end
	end
	return nil
end
OwnerPlot = getMyPlot()

-- Stock folders
local SeedsStock = ReplicatedStorage.StockValues.SeedShop.Items
local GearsStock = ReplicatedStorage.StockValues.GearShop.Items
local CratesStock = ReplicatedStorage.StockValues.CrateShop.Items

-- =============================================
-- HARVEST FUNCTIONS
-- =============================================

local function isGrown(plant)
	local maxAge = plant:GetAttribute("MaxAge")
	local age = plant:GetAttribute("Age")
	return maxAge and age and age >= maxAge
end

local function getHarvestablePlants()
	if not OwnerPlot then return {} end
	local result = {}
	local plantsFolder = OwnerPlot:FindFirstChild("Plants")
	if not plantsFolder then return result end

	for _, plant in ipairs(plantsFolder:GetChildren()) do
		local fruits = plant:FindFirstChild("Fruits")
		if fruits then
			for _, fruit in ipairs(fruits:GetChildren()) do
				if fruit:IsA("Model") and isGrown(fruit) then
					table.insert(result, fruit)
				end
			end
		elseif plant:IsA("Model") and isGrown(plant) then
			table.insert(result, plant)
		end
	end
	return result
end

local function harvest(plant)
	if not plant then return end
	local plantId = plant:GetAttribute("PlantId")
	local fruitId = plant:GetAttribute("FruitId") or ""
	if plantId then
		Networking.Garden.CollectFruit:Fire(plantId, fruitId)
	end
end

task.spawn(function()
	while task.wait(0.12) do
		if autoHarvest then
			if not OwnerPlot then OwnerPlot = getMyPlot() end
			if OwnerPlot then
				for _, plant in ipairs(getHarvestablePlants()) do
					if autoHarvest then
						harvest(plant)
						task.wait(0.02)
					end
				end
			end
		end
	end
end)

-- =============================================
-- AUTO-SELL & SELL ALL INVENTORY (Shared Function)
-- =============================================

local function sellAll()
	local ok, Net = pcall(function()
		return require(ReplicatedStorage.SharedModules.Networking)
	end)
	if ok and Net and Net.NPCS and Net.NPCS.SellAll then
		Net.NPCS.SellAll:Fire()
		return true
	else
		local Packet = ReplicatedStorage:FindFirstChild("SharedModules")
		if Packet then Packet = Packet:FindFirstChild("Packet") end
		if Packet then Packet = Packet:FindFirstChild("RemoteEvent") end
		if Packet then
			Packet:FireServer(buffer.fromstring("\157\000\018"))
			return true
		end
	end
	return false
end

task.spawn(function()
	while task.wait(sellCooldown) do
		if autoSell then
			pcall(sellAll)
		end
	end
end)

-- =============================================
-- AUTO-BUY
-- =============================================

local PurchaseSeeds = Networking.SeedShop.PurchaseSeed
local PurchaseGears = Networking.GearShop.PurchaseGear
local PurchaseCrates = Networking.CrateShop.PurchaseCrate

local prices = {}
local playerdata = nil
for i, v in pairs(getgc()) do
	if type(v) == "function" then
		if debug.info(v, "s"):match("RestockStoreController") then
			if debug.info(v, "l") == 575 then
				pcall(function()
					table.insert(prices, debug.getupvalue(v, 3))
					playerdata = debug.getupvalue(v, 9)
				end)
			end
		end
	end
end

local function canAfford(item)
	if not prices or not playerdata then return false end
	for _, options in pairs(prices) do
		local success, result = pcall(function()
			local itemData = options[item]
			if not itemData then return false end
			return (playerdata.Data.Sheckles or 0) >= itemData.price
		end)
		if success and result then
			return true
		end
	end
	return false
end

local function isExcluded(itemName)
	for _, excluded in pairs(excludedItems) do
		if excluded == itemName then
			return true
		end
	end
	return false
end

local function shouldBuyItem(itemName, selectedList)
	if isExcluded(itemName) then return false end
	if #selectedList == 0 then return false end
	for _, name in pairs(selectedList) do
		if name == itemName then
			return true
		end
	end
	return false
end

task.spawn(function()
	while task.wait(0.1) do
		if autoBuyEnabled then
			-- Buy Seeds
			for _, item in pairs(SeedsStock:GetChildren()) do
				if item:IsA("IntValue") and item.Value > 0 then
					if shouldBuyItem(item.Name, selectedSeeds) and canAfford(item.Name) then
						pcall(function() PurchaseSeeds:Fire(item.Name) end)
					end
				end
			end
			-- Buy Gears
			for _, item in pairs(GearsStock:GetChildren()) do
				if item:IsA("IntValue") and item.Value > 0 then
					if shouldBuyItem(item.Name, selectedGears) and canAfford(item.Name) then
						pcall(function() PurchaseGears:Fire(item.Name) end)
					end
				end
			end
			-- Buy Crates
			for _, item in pairs(CratesStock:GetChildren()) do
				if item:IsA("IntValue") and item.Value > 0 then
					if shouldBuyItem(item.Name, selectedCrates) and canAfford(item.Name) then
						pcall(function() PurchaseCrates:Fire(item.Name) end)
					end
				end
			end
		end
	end
end)

-- =============================================
-- AUTO-STEAL
-- =============================================

local function safeRequire(module)
	local success, result = pcall(function() return require(module) end)
	if not success then
		return nil
	end
	return result
end

local SharedModules = ReplicatedStorage:WaitForChild("SharedModules", 10)
local NetworkingModule = safeRequire(SharedModules:WaitForChild("Networking", 10))
local StealFlags = safeRequire(SharedModules:WaitForChild("Flags", 10):WaitForChild("StealFlags", 10))
local FruitValueCalc = safeRequire(SharedModules:WaitForChild("FruitValueCalc", 10))
local PlantCycleModule = safeRequire(LocalPlayer:WaitForChild("PlayerScripts", 10):WaitForChild("Controllers", 10):WaitForChild("PlantLifecycleHandler", 10))

local Night = ReplicatedStorage:WaitForChild("Night", 10)

local function isNightTime()
	if not Night then return false end
	local success, isBool = pcall(function() return Night:IsA("BoolValue") end)
	if not success or not isBool then return false end
	return Night.Value == true
end

local function canSteal(player)
	if not player then return false end
	local suc, result = pcall(function()
		return player:GetAttribute("IsInOwnGarden")
	end)
	return result or false
end

local function teleportTo(hrp, startCFrame, targetCFrame, speed)
	if not targetCFrame or typeof(targetCFrame) ~= "CFrame" then return end
	if not startCFrame or typeof(startCFrame) ~= "CFrame" then return end
	if not hrp or typeof(hrp) ~= "Instance" then return end
	if not speed or typeof(speed) ~= "number" or speed <= 0 then return end

	local distance = (targetCFrame.Position - startCFrame.Position).Magnitude
	local duration = distance / speed
	local elp = 0
	local con

	pcall(function()
		con = RunService.RenderStepped:Connect(function(dt)
			pcall(function()
				elp = elp + dt
				if elp >= duration then
					if hrp and hrp.Parent ~= nil then hrp.CFrame = targetCFrame end
					if con then con:Disconnect() end
					return
				end
				local alpha = elp / duration
				if hrp and hrp.Parent ~= nil then
					hrp.CFrame = startCFrame:Lerp(targetCFrame, alpha)
				else
					if con then con:Disconnect() end
					return
				end
			end)
		end)
	end)

	if not con then return end
	local waitStart = tick()
	while con.Connected and tick() - waitStart < duration + 2 do task.wait() end
	if con.Connected then pcall(function() con:Disconnect() end) end
end

local function getDecay(model)
	if not PlantCycleModule then return 0 end
	local success, Entries = pcall(function() return PlantCycleModule:GetActiveEntries() end)
	if not success or not Entries or typeof(Entries) ~= "table" then return 0 end
	if not model or not model:IsA("Model") then return 0 end

	for plantid, planttable in pairs(Entries) do
		local found = false
		local decayValue = 0
		pcall(function()
			if planttable and planttable.Model and planttable.Model == model then
				local a, b = string.match(plantid, "^(%d+)_(.+)$")
				if a and b then
					local decaySuccess, decay = pcall(function()
						return PlantCycleModule:GetDecayAlpha(tonumber(a), b)
					end)
					if decaySuccess then
						decayValue = decay or 0
						found = true
					end
				end
			end
		end)
		if found then return decayValue end
	end
	return 0
end

local function getHarvestableStealPlants()
	local stealable = {}
	if not gardens then return stealable end
	
	for _, plot in pairs(gardens:GetChildren()) do
		if plot and plot:IsA("Model") then
			local Plants = plot:FindFirstChild("Plants")
			if Plants then
				for _, model in pairs(Plants:GetChildren()) do
					if model and model:IsA("Model") then
						local Fruits = model:FindFirstChild("Fruits")
						if Fruits then
							for _, fruit in pairs(Fruits:GetChildren()) do
								if fruit and fruit:IsA("Model") then
									local seedName = model:GetAttribute("SeedName") or model:GetAttribute("CorePartName")
									if seedName then
										local plantid = model:GetAttribute("PlantId")
										if plantid and StealFlags and StealFlags.IsPlantStealable then
											local valid = StealFlags.IsPlantStealable(seedName)
											if valid then
												local targetuserid = model:GetAttribute("UserId")
												if targetuserid then
													local targetplayer = Players:GetPlayerByUserId(tonumber(targetuserid))
													if targetplayer and not canSteal(targetplayer) then
														table.insert(stealable, model)
													end
												end
											end
										end
									end
								end
							end
						end
					end
				end
			end
		end
	end
	return stealable
end

local function performSteal(model)
	if not isNightTime() then
		return false
	end
	if not model then
		return false
	end

	local ownerId = tonumber(model:GetAttribute("UserId"))
	if not ownerId then return false end

	local plantId = model:GetAttribute("PlantId")
	if not plantId or type(plantId) ~= "string" then
		return false
	end

	local fruitId = model:GetAttribute("FruitId") or ""
	if type(fruitId) ~= "string" then
		return false
	end

	local char = LocalPlayer.Character
	if not char then return false end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end

	local plotsizeref = OwnerPlot:FindFirstChild("PlotSizeReference")
	if not plotsizeref then return false end

	local oldPos = plotsizeref.CFrame
	local basePart = model:FindFirstChildWhichIsA("BasePart")
	if not basePart then return false end

	local target = basePart.CFrame + Vector3.new(0, 3, 0)

	teleportTo(hrp, oldPos, target, 33.8)
	task.wait(1)

	if NetworkingModule and NetworkingModule.Steal then
		if NetworkingModule.Steal.BeginSteal then
			NetworkingModule.Steal.BeginSteal:Fire(ownerId, plantId, fruitId)
		end
		if NetworkingModule.Steal.CompleteSteal then
			NetworkingModule.Steal.CompleteSteal:Fire()
		end
	else
		teleportTo(hrp, target, oldPos, 33.8)
		return false
	end

	task.wait(1)
	teleportTo(hrp, target, oldPos, 33.8)
	return true
end

task.spawn(function()
	while task.wait(1) do
		if autoStealEnabled then
			pcall(function()
				local plants = getHarvestableStealPlants()
				if #plants == 0 then
					return
				end
				for _, plant in pairs(plants) do
					if autoStealEnabled then
						local success = performSteal(plant)
						if success then
							task.wait(0.5)
						end
					end
				end
			end)
		end
	end
end)
