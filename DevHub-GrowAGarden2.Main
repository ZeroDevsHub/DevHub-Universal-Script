-- =============================================
-- ESP FUNCTIONS (ENEMY HIGHLIGHT - FIXED RED)
-- =============================================

local function updateESP()
	if not espEnabled then
		if espHolder then
			espHolder:Destroy()
			espHolder = nil
		end
		return
	end

	if not espHolder then
		espHolder = Instance.new("Folder")
		espHolder.Name = "ESPHolder"
		espHolder.Parent = CoreGui
	end

	local enemyFillColor = Color3.fromRGB(180, 0, 0)
	local enemyOutlineColor = Color3.fromRGB(255, 0, 0)

	for _, player in pairs(Players:GetPlayers()) do
		local char = player.Character
		if char then
			if not useLocalPlayer and player == LocalPlayer then
				if espHolder:FindFirstChild(player.Name) then
					espHolder:FindFirstChild(player.Name):Destroy()
				end
				continue
			end
			
			local esp = espHolder:FindFirstChild(player.Name)
			if not esp then
				esp = Instance.new("Highlight")
				esp.Name = player.Name
				esp.Parent = espHolder
			end
			
			esp.FillColor = enemyFillColor
			esp.OutlineColor = enemyOutlineColor
			esp.FillTransparency = fillTransparency
			esp.OutlineTransparency = outlineTransparency
			esp.Adornee = char
			esp.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		end
	end
	
	for _, esp in pairs(espHolder:GetChildren()) do
		if not Players:FindFirstChild(esp.Name) then
			esp:Destroy()
		end
	end
end

