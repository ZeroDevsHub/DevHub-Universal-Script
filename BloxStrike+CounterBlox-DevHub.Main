-- =============================================
-- ESP SYSTEM (OPTIMIZED)
-- =============================================
local espDrawings = {}

local function isTeammate(p)
    if not _G.Config.EspTeamCheck then return false end
    if not LocalPlayer.Team or not p.Team then return false end
    return p.TeamColor == LocalPlayer.TeamColor
end

local function getRootPart(p) return p.Character and p.Character:FindFirstChild("HumanoidRootPart") end
local function getHumanoid(p) return p.Character and p.Character:FindFirstChildOfClass("Humanoid") end
local function getHead(p) return p.Character and p.Character:FindFirstChild("Head") end
local function isAlive(p) local h = getHumanoid(p); return h and h.Health > 0 end

local function killDrawing(obj) if obj then pcall(function() obj.Visible = false; obj:Remove() end) end end

local function destroyEsp(player)
    local d = espDrawings[player]
    if not d then return end
    killDrawing(d.box)
    killDrawing(d.hpBg)
    killDrawing(d.hpBar)
    killDrawing(d.distText)
    killDrawing(d.nameText)
    killDrawing(d.tracer)
    if d.skel then for _,l in ipairs(d.skel) do killDrawing(l) end end
    if d.highlight then pcall(function() d.highlight:Destroy() end) end
    espDrawings[player] = nil
end

local function getOrCreateEsp(player)
    local name = player.Name
    if espDrawings[name] then return espDrawings[name] end
    local d = {}
    d.box = Drawing.new("Square")
    d.box.Visible = false; d.box.Filled = false; d.box.Thickness = _G.Config.EspBoxThick
    d.hpBg = Drawing.new("Square")
    d.hpBg.Visible = false; d.hpBg.Filled = true; d.hpBg.Color = Color3.fromRGB(12,12,12); d.hpBg.Transparency = 0.35
    d.hpBar = Drawing.new("Square")
    d.hpBar.Visible = false; d.hpBar.Filled = true; d.hpBar.Color = Color3.fromRGB(0,215,75)
    d.distText = Drawing.new("Text")
    d.distText.Visible = false; d.distText.Size = 13; d.distText.Font = Drawing.Fonts.UI
    d.distText.Center = true; d.distText.Outline = true; d.distText.OutlineColor = Color3.fromRGB(0,0,0)
    d.nameText = Drawing.new("Text")
    d.nameText.Visible = false; d.nameText.Size = 13; d.nameText.Font = Drawing.Fonts.UI
    d.nameText.Center = true; d.nameText.Outline = true; d.nameText.OutlineColor = Color3.fromRGB(0,0,0)
    d.tracer = Drawing.new("Line")
    d.tracer.Visible = false; d.tracer.Thickness = 1
    d.skel = {}
    local skelPairs = {
        {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
        {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
        {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
        {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
        {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    }
    for i = 1, #skelPairs do
        local l = Drawing.new("Line")
        l.Visible = false; l.Thickness = 1
        d.skel[i] = l
    end
    d.highlight = nil
    espDrawings[name] = d
    return d
end

local espUpdateCounter = 0
local function updatePlayerEsp(player)
    if player == LocalPlayer then return end
    local d = getOrCreateEsp(player)
    local alive = isAlive(player)
    local mate = isTeammate(player)
    local show = alive and not (mate and _G.Config.EspTeamCheck)
    local hrp = getRootPart(player)
    local col = mate and _G.Config.EspFriendColor or _G.Config.EspEnemyColor

    local sb = nil
    if show and hrp then
        local headP = getHead(player)
        local topPos = headP and (headP.Position + Vector3.new(0,0.55,0)) or (hrp.Position + Vector3.new(0,3,0))
        local botPos = hrp.Position - Vector3.new(0,3.05,0)
        local top, tv = Camera:WorldToViewportPoint(topPos)
        local bot, bv = Camera:WorldToViewportPoint(botPos)
        local dist = (hrp.Position - Camera.CFrame.Position).Magnitude
        if tv and bv and top.Z > 0 and bot.Z > 0 and dist <= _G.Config.EspMaxDist then
            local bH = math.abs(top.Y - bot.Y)
            local bW = bH * 0.58
            sb = {x = top.X - bW/2, y = math.min(top.Y, bot.Y), w = bW, h = bH, dist = dist}
        end
    end

    if _G.Config.EspBoxes and sb then
        d.box.Size = Vector2.new(sb.w, sb.h)
        d.box.Position = Vector2.new(sb.x, sb.y)
        d.box.Color = col
        d.box.Thickness = _G.Config.EspBoxThick
        d.box.Visible = true
    else d.box.Visible = false end

    if _G.Config.EspHealth and sb then
        local hum = getHumanoid(player)
        local pct = hum and math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1) or 1
        local fullH = sb.h
        local fillH = math.max(1, fullH * pct)
        local barX = sb.x - 5 - 3
        d.hpBg.Size = Vector2.new(4, fullH)
        d.hpBg.Position = Vector2.new(barX, sb.y)
        d.hpBg.Visible = true
        d.hpBar.Size = Vector2.new(2, fullH * pct)
        d.hpBar.Position = Vector2.new(barX + 1, sb.y + fullH * (1 - pct))
        d.hpBar.Color = Color3.fromRGB(0, 215, 75)
        d.hpBar.Visible = true
    else d.hpBg.Visible = false; d.hpBar.Visible = false end

    if _G.Config.EspDistance and sb then
        d.distText.Text = math.floor(sb.dist) .. "m"
        d.distText.Position = Vector2.new(sb.x + sb.w/2, sb.y - 16)
        d.distText.Color = Color3.fromRGB(195,215,255)
        d.distText.Visible = true
    else d.distText.Visible = false end

    if _G.Config.EspNames and sb then
        d.nameText.Text = player.Name
        d.nameText.Position = Vector2.new(sb.x + sb.w/2, sb.y - (_G.Config.EspDistance and -29 or -16))
        d.nameText.Color = col
        d.nameText.Visible = true
    else d.nameText.Visible = false end

    if _G.Config.EspTracers and show and hrp then
        local footPos = hrp.Position - Vector3.new(0,3.05,0)
        local sp, on = Camera:WorldToViewportPoint(footPos)
        local dist = (hrp.Position - Camera.CFrame.Position).Magnitude
        if on and sp.Z > 0 and dist <= _G.Config.EspMaxDist then
            local vp = Camera.ViewportSize
            d.tracer.From = Vector2.new(vp.X/2, vp.Y)
            d.tracer.To = Vector2.new(sp.X, sp.Y)
            d.tracer.Color = col
            d.tracer.Thickness = 1
            d.tracer.Visible = true
        else d.tracer.Visible = false end
    else d.tracer.Visible = false end

    local used = 0
    if _G.Config.EspSkeleton and show and player.Character then
        local char = player.Character
        for _, pair in ipairs({
            {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
            {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},
            {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},
            {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},
            {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},
        }) do
            local pA = char:FindFirstChild(pair[1])
            local pB = char:FindFirstChild(pair[2])
            if pA and pB then
                local spA, onA = Camera:WorldToViewportPoint(pA.Position)
                local spB, onB = Camera:WorldToViewportPoint(pB.Position)
                if onA and onB and spA.Z > 0 and spB.Z > 0 then
                    used = used + 1
                    local sl = d.skel[used]
                    if sl then
                        sl.From = Vector2.new(spA.X, spA.Y)
                        sl.To = Vector2.new(spB.X, spB.Y)
                        sl.Color = _G.Config.EspSkelColor
                        sl.Thickness = 1
                        sl.Visible = true
                    end
                end
            end
        end
    end
    for i = used + 1, 10 do
        local sl = d.skel[i]
        if sl then sl.Visible = false end
    end

    if _G.Config.EspEnabled and show and player.Character then
        if not d.highlight or d.highlight.Parent == nil then
            if d.highlight then pcall(function() d.highlight:Destroy() end) end
            local hl = Instance.new("Highlight")
            hl.Adornee = player.Character
            hl.FillColor = col
            hl.OutlineColor = col
            hl.FillTransparency = 0.60
            hl.OutlineTransparency = 0.05
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Parent = player.Character
            d.highlight = hl
        end
    elseif d.highlight then
        pcall(function() d.highlight:Destroy() end)
        d.highlight = nil
    end
end

