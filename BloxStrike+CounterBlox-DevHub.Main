-- =============================================
-- CROSSHAIR
-- =============================================
local chLines = {}
for i = 1, 4 do 
    local l = Drawing.new("Line")
    l.Visible = false
    l.Thickness = 1.5
    l.Color = _G.Config.CrosshairColor
    chLines[i] = l
end
local chDot = Drawing.new("Circle")
chDot.Visible = false
chDot.Radius = 2
chDot.Color = _G.Config.CrosshairColor
chDot.Filled = true
chDot.Thickness = 1

local function updateCrosshair()
    if not _G.Config.CrosshairEnabled then
        for i = 1, 4 do chLines[i].Visible = false end
        chDot.Visible = false
        return
    end
    if UserInputService:GetFocusedTextBox() then return end
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2
    local g = _G.Config.CrosshairGap
    local s = _G.Config.CrosshairSize
    chLines[1].From = Vector2.new(cx, cy - g)
    chLines[1].To = Vector2.new(cx, cy - g - s)
    chLines[2].From = Vector2.new(cx, cy + g)
    chLines[2].To = Vector2.new(cx, cy + g + s)
    chLines[3].From = Vector2.new(cx - g, cy)
    chLines[3].To = Vector2.new(cx - g - s, cy)
    chLines[4].From = Vector2.new(cx + g, cy)
    chLines[4].To = Vector2.new(cx + g + s, cy)
    for i = 1, 4 do
        chLines[i].Color = _G.Config.CrosshairColor
        chLines[i].Visible = true
    end
    chDot.Position = Vector2.new(cx, cy)
    chDot.Color = _G.Config.CrosshairColor
    chDot.Visible = true
end

-- =============================================
-- SILENT AIM / GET CLOSEST TARGET
-- =============================================
local function getClosestTarget(fovRadius)
    fovRadius = fovRadius or _G.Config.FovRadius
    local best, bestDist, bestPos = nil, fovRadius, nil
    local vp = Camera.ViewportSize
    local ctr = Vector2.new(vp.X / 2, vp.Y / 2)

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or isTeammate(p) or not isAlive(p) then continue end
        local bone = p.Character:FindFirstChild(_G.Config.AimPart or "Head") or getRootPart(p)
        if not bone then continue end

        local worldPos = bone.Position
        if _G.Config.AimbotPrediction and getRootPart(p) then
            worldPos = worldPos + getRootPart(p).Velocity * _G.Config.PredictionAmount
        end

        local sp, onScreen = Camera:WorldToViewportPoint(worldPos)
        if not onScreen or sp.Z <= 0 then continue end

        local screenPos = Vector2.new(sp.X, sp.Y)
        local dist = (screenPos - ctr).Magnitude
        if dist < bestDist then
            bestDist = dist
            best = bone
            bestPos = worldPos
        end
    end
    return best, bestPos
end

local function draw_tracer(origin, target_pos)
    local beam = Instance.new("Beam")
    local att0 = Instance.new("Attachment")
    local att1 = Instance.new("Attachment")
    local part0 = Instance.new("Part", Workspace)
    part0.Size = Vector3.new(0.01, 0.01, 0.01)
    part0.Position = origin
    part0.Anchored = true
    part0.Transparency = 1
    part0.CanCollide = false
    local part1 = Instance.new("Part", Workspace)
    part1.Size = Vector3.new(0.01, 0.01, 0.01)
    part1.Position = target_pos
    part1.Anchored = true
    part1.Transparency = 1
    part1.CanCollide = false
    att0.Parent = part0
    att1.Parent = part1
    beam.Attachment0 = att0
    beam.Attachment1 = att1
    beam.Parent = Workspace
    beam.Texture = "http://www.roblox.com/asset/?id=446111271"
    beam.TextureSpeed = 4
    beam.Width0 = 0.15
    beam.Width1 = 0.15
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Color = ColorSequence.new(_G.Config.BulletTracerColor or Color3.fromRGB(80, 200, 255))
    beam.Transparency = NumberSequence.new(0)
    task.delay(_G.Config.TracerDuration or 1.5, function()
        beam:Destroy()
        part0:Destroy()
        part1:Destroy()
    end)
end

local function SpawnHitmarker(position)
    if not _G.Config.ShowHitmark then return end
    local hitpart = Instance.new("Part", Workspace)
    hitpart.Transparency = 1
    hitpart.CanCollide = false
    hitpart.CanQuery = false
    hitpart.Size = Vector3.new(0.01,0.01,0.01)
    hitpart.Anchored = true
    hitpart.Position = position
    hitpart.Name = "BloxStrikeHitmarker"
    local hit = Instance.new("BillboardGui")
    hit.Name = "hit"
    hit.AlwaysOnTop = true
    hit.Parent = hitpart
    hit.Size = UDim2.new(0, 50, 0, 50)
    hit.Adornee = hitpart
    local hit_img = Instance.new("ImageLabel")
    hit_img.Name = "hit_img"
    hit_img.Image = "http://www.roblox.com/asset/?id=10922361372"
    hit_img.BackgroundTransparency = 1
    hit_img.Size = UDim2.new(0, 23, 0, 23)
    hit_img.Visible = true
    hit_img.ImageColor3 = _G.Config.HitmarkColor or Color3.new(1,1,1)
    hit_img.Rotation = 45
    hit_img.AnchorPoint = Vector2.new(0.5, 0.5)
    hit_img.Position = UDim2.new(0.5, 0, 0.5, 0)
    hit_img.Parent = hit
    task.spawn(function()
        local duration = _G.Config.HitmarkDuration or 0.5
        local ts = game:GetService("TweenService")
        local tweninfo = TweenInfo.new(duration, Enum.EasingStyle.Sine)
        local tweninfo2 = TweenInfo.new(duration, Enum.EasingStyle.Linear)
        ts:Create(hit_img, tweninfo, {ImageTransparency = 1}):Play()
        ts:Create(hit_img, tweninfo2, {Rotation = 180}):Play()
        task.wait(duration)
        if hit_img then hit_img:Destroy() end
        if hit then hit:Destroy() end
        if hitpart then hitpart:Destroy() end
    end)
end

local function playHitSound()
    if not _G.Config.PlayHitSound then return end
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://1255040462"
    s.Volume = 1
    s.PlayOnRemove = true
    s.Parent = Workspace
    s:Destroy()
end

-- =============================================
-- HOOK BULLET MODULE (with fallback)
-- =============================================
local function SetupSilentAim()
    local success, err = pcall(function()
        local BulletModule = ReplicatedStorage:FindFirstChild("Components")
        if not BulletModule then return end
        local WeaponModule = BulletModule:FindFirstChild("Weapon")
        if not WeaponModule then return end
        local ClassesModule = WeaponModule:FindFirstChild("Classes")
        if not ClassesModule then return end
        local Bullet = ClassesModule:FindFirstChild("Bullet")
        if not Bullet then return end
        
        local BulletModule = require(Bullet)
        local originalPerformRaycast = BulletModule._performRaycast
        
        if originalPerformRaycast then
            BulletModule._performRaycast = function(self, spreadAmount)
                if _G.Config.NoSpread or _G.Config.SilentAim then
                    spreadAmount = 0
                end
                local target, targetPart, targetPoint = getClosestTarget(_G.Config.FovRadius or 150)
                local startPos = Camera and Camera.CFrame.Position
                if _G.Config.SilentAim and target and target.Character and targetPart and startPos then
                    local targetPos = targetPoint or targetPart.Position
                    local originalCamCFrame = Camera.CFrame
                    Camera.CFrame = CFrame.new(startPos, targetPos)
                    local direction = (targetPos - startPos).Unit
                    local fakeResult = {
                        Hits = {{Instance = targetPart, Position = targetPos, Normal = Vector3.new(0, 1, 0)}},
                        Ray = Ray.new(startPos, direction),
                        Instance = targetPart,
                        Position = targetPos,
                    }
                    Camera.CFrame = originalCamCFrame
                    
                    if _G.Config.ShowTracers then draw_tracer(startPos, targetPos) end
                    if _G.Config.PlayHitSound then playHitSound() end
                    if _G.Config.ShowHitmark then SpawnHitmarker(targetPos) end
                    
                    return fakeResult
                end
                
                local result = originalPerformRaycast(self, spreadAmount)
                if result and result.Hits then
                    local finalHit = result.Hits[#result.Hits]
                    if finalHit and finalHit.Instance and finalHit.Position then
                        if _G.Config.ShowTracers then draw_tracer(startPos, finalHit.Position) end
                        if _G.Config.PlayHitSound then playHitSound() end
                        if _G.Config.ShowHitmark then SpawnHitmarker(finalHit.Position) end
                    end
                end
                return result
            end
        end
    end)
    if not success then
        warn("Silent aim hook failed: " .. tostring(err))
    end
end

-- =============================================
-- MOBILE AUTO-FIRE
-- =============================================
local mobileShootTimer = 0

local function MobileAutoFire()
    if not _G.Config.AutoFireMobile then return end
    if not IsMobile then return end
    
    local target, targetPos = getClosestTarget(_G.Config.FovRadius)
    if not target or not targetPos then return end
    
    local now = tick()
    if now - mobileShootTimer < _G.Config.AutoShootDelay then return end
    
    local vp = Camera.ViewportSize
    local ctr = Vector2.new(vp.X / 2, vp.Y / 2)
    local sp, onScreen = Camera:WorldToViewportPoint(targetPos)
    if not onScreen then return end
    local screenPos = Vector2.new(sp.X, sp.Y)
    local dist = (screenPos - ctr).Magnitude
    if dist > _G.Config.FovRadius then return end
    
    mobileShootTimer = now
    pcall(function()
        local vi = game:GetService("VirtualInputManager")
        vi:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.05)
        vi:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
end

