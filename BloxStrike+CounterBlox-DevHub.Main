-- =============================================
-- ANTI-FLASHBANG (optimized)
-- =============================================
local flashConns = {}
local function killFlashObj(obj)
    if obj:IsA("Frame") or obj:IsA("ImageLabel") then
        if obj.BackgroundTransparency < 0.1 then
            local c = obj.BackgroundColor3
            if c.R > 0.85 and c.G > 0.85 and c.B > 0.85 then obj.BackgroundTransparency = 1 end
        end
    elseif obj:IsA("ColorCorrectionEffect") then
        if obj.Brightness > 0.4 then obj.Brightness = 0 end
    elseif obj:IsA("BlurEffect") then obj.Size = 0 end
end
local function enableAntiFlash()
    for _,c in ipairs(flashConns) do pcall(function() c:Disconnect() end) end
    flashConns = {}
    local L = game:GetService("Lighting")
    local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if pg then
        for _,obj in ipairs(pg:GetDescendants()) do pcall(killFlashObj, obj) end
        local c = pg.DescendantAdded:Connect(function(obj) if _G.Config.AntiFlashEnabled then task.wait(); pcall(killFlashObj, obj) end end)
        table.insert(flashConns, c)
    end
    for _,eff in ipairs(L:GetChildren()) do pcall(killFlashObj, eff) end
    local lc = L.ChildAdded:Connect(function(obj) if _G.Config.AntiFlashEnabled then task.wait(); pcall(killFlashObj, obj) end end)
    table.insert(flashConns, lc)
end
local function disableAntiFlash()
    for _,c in ipairs(flashConns) do pcall(function() c:Disconnect() end) end
    flashConns = {}
    for _,eff in ipairs(game:GetService("Lighting"):GetChildren()) do
        if eff:IsA("BlurEffect") then eff.Size = 24 end
    end
end

-- =============================================
-- RUN SERVICES (OPTIMIZED)
-- =============================================
local triggerLast = 0
local frameCounter = 0

RunService.RenderStepped:Connect(function()
    frameCounter = frameCounter + 1
    local vp = Camera.ViewportSize
    local ctr = Vector2.new(vp.X / 2, vp.Y / 2)
    
    -- FOV Circle
    if _G.Config.ShowFov then
        fovCircle.Position = ctr
        fovCircle.Radius = _G.Config.FovRadius or 150
        fovCircle.Color = _G.Config.FovColor or Color3.fromRGB(255, 255, 255)
        fovCircle.Visible = true
    else
        fovCircle.Visible = false
    end
    
    -- Custom FOV
    if _G.Config.EnableFov then
        Camera.FieldOfView = _G.Config.CustomFov
    end
    
    -- No Flash
    if _G.Config.NoFlash then
        local gui = LocalPlayer.PlayerGui:FindFirstChild("FlashbangEffect")
        if gui then gui:Destroy() end
        local lightingEffect = game:GetService("Lighting"):FindFirstChild("FlashbangColorCorrection")
        if lightingEffect then lightingEffect:Destroy() end
    end
    
    -- Anti-Flash
    if _G.Config.AntiFlashEnabled then
        enableAntiFlash()
    else
        disableAntiFlash()
    end
    
    -- Crosshair (only every 2 frames to save CPU)
    if frameCounter % 2 == 0 then
        updateCrosshair()
    end
    
    -- Aimbot
    if _G.Config.AimbotEnabled then
        local isAiming = false
        if IsMobile then
            isAiming = #UserInputService:GetTouchPositions() > 0
        else
            isAiming = _G.Config.RMBHeld
        end
        if isAiming then
            local _, worldPos = getClosestTarget(_G.Config.FovRadius)
            if worldPos then
                local origin = Camera.CFrame.Position
                local _, onScreen = Camera:WorldToViewportPoint(worldPos)
                if onScreen then
                    local alpha = math.clamp(_G.Config.AimbotSmooth / 10, 0.04, 1.0)
                    local targetCF = CFrame.lookAt(origin, worldPos)
                    Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
                end
            end
        end
    end
    
    -- Mobile Auto-Fire (every 2 frames)
    if IsMobile and _G.Config.AutoFireMobile and frameCounter % 2 == 0 then
        pcall(MobileAutoFire)
    end
    
    -- Triggerbot
    if _G.Config.TriggerbotEnabled then
        local now = tick()
        if now - triggerLast >= _G.Config.TriggerbotDelay then
            local char = LocalPlayer.Character
            if char then
                local ray = Ray.new(Camera.CFrame.Position, Camera.CFrame.LookVector * 600)
                local hit = Workspace:FindPartOnRayWithIgnoreList(ray, {char})
                if hit then
                    local model = hit:FindFirstAncestorOfClass("Model")
                    if model then
                        for _, p in pairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character == model and not isTeammate(p) and isAlive(p) then
                                triggerLast = now
                                pcall(function()
                                    local vi = game:GetService("VirtualInputManager")
                                    vi:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                                    task.wait(0.05)
                                    vi:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                                end)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- ESP (only every 3 frames to reduce load)
    if _G.Config.EspEnabled and frameCounter % 3 == 0 then
        for _, p in pairs(Players:GetPlayers()) do
            pcall(updatePlayerEsp, p)
        end
    elseif not _G.Config.EspEnabled then
        for name, d in pairs(espDrawings) do
            if d.box then d.box.Visible = false end
            if d.hpBg then d.hpBg.Visible = false end
            if d.hpBar then d.hpBar.Visible = false end
            if d.distText then d.distText.Visible = false end
            if d.nameText then d.nameText.Visible = false end
            if d.tracer then d.tracer.Visible = false end
            if d.skel then for _,l in ipairs(d.skel) do l.Visible = false end end
            if d.highlight then pcall(function() d.highlight:Destroy() end); d.highlight = nil end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if _G.Config.Bhop then
        local hum = getHumanoid(LocalPlayer)
        if hum and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

UserInputService.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then
        _G.Config.RMBHeld = true
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then
        _G.Config.RMBHeld = false
    end
end)

-- =============================================
-- PLAYER HOOKS
-- =============================================
local function hookPlayer(p)
    p.CharacterAdded:Connect(function()
        task.wait(0.55)
        local d = espDrawings[p.Name]
        if d then
            if d.highlight then pcall(function() d.highlight:Destroy() end); d.highlight = nil end
            if d.box then d.box.Visible = false end
            if d.hpBg then d.hpBg.Visible = false end
            if d.hpBar then d.hpBar.Visible = false end
            if d.distText then d.distText.Visible = false end
            if d.nameText then d.nameText.Visible = false end
            if d.tracer then d.tracer.Visible = false end
            if d.skel then for _,l in ipairs(d.skel) do l.Visible = false end end
        end
    end)
    p.CharacterRemoving:Connect(function()
        local d = espDrawings[p.Name]
        if d then
            if d.highlight then pcall(function() d.highlight:Destroy() end); d.highlight = nil end
            if d.box then d.box.Visible = false end
            if d.hpBg then d.hpBg.Visible = false end
            if d.hpBar then d.hpBar.Visible = false end
            if d.distText then d.distText.Visible = false end
            if d.nameText then d.nameText.Visible = false end
            if d.tracer then d.tracer.Visible = false end
            if d.skel then for _,l in ipairs(d.skel) do l.Visible = false end end
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then hookPlayer(p) end
end

Players.PlayerAdded:Connect(function(p) hookPlayer(p) end)
Players.PlayerRemoving:Connect(function(p)
    destroyEsp(p.Name)
end)

